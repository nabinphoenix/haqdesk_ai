# HaqDesk AI - Environment Configuration
# Copy this file to .env and fill in your credentials

# ============================================
# Meta Platforms (Facebook, Instagram, WhatsApp)
# ============================================
# Get these from https://developers.facebook.com
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here

# Meta Webhook Verification Token (create a random string)
META_VERIFY_TOKEN=your_random_verify_token_here_12345

# ============================================
# TikTok Platform
# ============================================
# Get these from https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ============================================
# Application URLs
# ============================================
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations
FRONTEND_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/haqdesk
# For development, you can use SQLite:
# DATABASE_URL=sqlite:///./haqdesk.db

# ============================================
# Security
# ============================================
SECRET_KEY=your_secret_key_for_jwt_tokens_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# AI Services & LLM Gateway
# ============================================
# LLM Router configuration
LLM_PRIMARY_MODEL=groq/llama-3.3-70b-versatile
LLM_FALLBACK_MODELS=gemini/gemini-2.0-flash,openrouter/meta-llama/llama-3.1-70b-instruct
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES_PER_MODEL=1
LLM_FALLBACK_ENABLED=true

# API Keys (Provide only the keys for the services you use)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Redis (for WebSocket/real-time features)
# ============================================
REDIS_URL=redis://localhost:6379/0
