# HaqDesk AI - Environment Configuration
# Copy this file to .env and fill in your credentials

# ============================================
# Meta Platforms (Facebook, Instagram, WhatsApp)
# ============================================
# Get these from https://developers.facebook.com
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here

# Meta Webhook Verification Token (create a random string)
META_VERIFY_TOKEN=your_random_verify_token_here_12345

# ============================================
# TikTok Platform
# ============================================
# Get these from https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ============================================
# Application URLs
# ============================================
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations
FRONTEND_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/haqdesk
# For development, you can use SQLite:
# DATABASE_URL=sqlite:///./haqdesk.db

# ============================================
# Security
# ============================================
SECRET_KEY=your_secret_key_for_jwt_tokens_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# AI Service (Optional)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Redis (for WebSocket/real-time features)
# ============================================
REDIS_URL=redis://localhost:6379/0
